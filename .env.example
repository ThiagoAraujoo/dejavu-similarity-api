APP_PORT=3000
NODE_ENV=develop

JWT_SECRET=
WEBSOCKET_AUTH_TOKEN=

SEMANTIC_DETECTOR_PATH=src/core/scripts/semantic_similarity_detector.py

SIMILARITY_SERVICE_URL=http://127.0.0.1:8002/detect

SIMILARITY_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
SIMILARITY_MODEL_PATH=/opt/dejavu/backend/models/sentence-transformer

SIMILARITY_WORKERS=4
SIMILARITY_WINDOW_SIZE=50
SIMILARITY_WINDOW_OVERLAP=25
SIMILARITY_THRESHOLD=45.0

AUTO_APPROVAL_THRESHOLD=70.0
PARTIAL_MATCH_THRESHOLD=30.0
MAX_CONCURRENT_TASKS=4
TASK_TIMEOUT_SECONDS=30

RUST_LOG=info