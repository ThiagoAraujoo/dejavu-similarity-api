APP_PORT=3000
NODE_ENV=develop

JWT_SECRET=
WEBSOCKET_AUTH_TOKEN=

# WhisperX Service Configuration
WHISPERX_SERVICE_URL=http://127.0.0.1:8001
WHISPER_MODEL=large-v3
WHISPER_LANGUAGE=pt

# WhisperX Service Settings (used by whisperx_service.py)
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

MAX_CONCURRENT_TRANSCRIPTIONS=2
TRANSCRIPTION_TIMEOUT_SECONDS=120 

SEMANTIC_DETECTOR_PATH=/app/core/scripts/semantic_similarity_detector.py
SIMILARITY_WORKERS=4
SIMILARITY_THRESHOLD=45.0
AUTO_APPROVAL_THRESHOLD=70.0 

RUST_LOG=info